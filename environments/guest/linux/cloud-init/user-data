#cloud-config
# cloud-init config for the graphics-benchmark guest (Ubuntu 24.04 cloud image).
# Placeholders @USERNAME@/@HOSTNAME@/@SSH_PUBKEY@ are filled by create-vmdisk.sh
# before the NoCloud seed ISO is built.

hostname: "@HOSTNAME@"

# Replace the default 'ubuntu' user with our own.
users:
  - name: "@USERNAME@"
    # passwordless sudo
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    groups: [adm, sudo, video, render, kvm]
    shell: /bin/bash
    lock_passwd: false          # account stays usable; password is emptied below
    ssh_authorized_keys:
      - "@SSH_PUBKEY@"

# Allow password SSH off (we use keys). Console login is passwordless.
ssh_pwauth: false

# Empty the password so console/login needs no password (SSH stays key-only).
runcmd:
  - [ passwd, -d, "@USERNAME@" ]
  - [ systemctl, enable, --now, ssh ]
  # GDM: autologin our user into a GNOME *Xorg* (X11) session, with Wayland off.
  - |
    mkdir -p /etc/gdm3
    cat > /etc/gdm3/custom.conf <<EOF
    [daemon]
    WaylandEnable=false
    AutomaticLoginEnable=true
    AutomaticLogin=@USERNAME@
    DefaultSession=ubuntu-xorg
    EOF
  # Default the user's session to GNOME-on-Xorg so autologin lands in X11.
  - |
    mkdir -p /var/lib/AccountsService/users
    cat > /var/lib/AccountsService/users/@USERNAME@ <<EOF
    [User]
    Session=ubuntu-xorg
    XSession=ubuntu-xorg
    SystemAccount=false
    EOF
  # Boot into the graphical target and make GDM the active display manager.
  # gdm3.service has no [Install] section (it's wired via the display-manager
  # alias), so `systemctl enable gdm3` is a no-op/"alias" — set it the Debian way
  # by pointing display-manager.service at gdm and recording it for the DM
  # selection, then ensure graphical.target is the default.
  - [ systemctl, set-default, graphical.target ]
  - [ sh, -c, "echo /usr/sbin/gdm3 > /etc/X11/default-display-manager" ]
  - [ sh, -c, "ln -sf /usr/lib/systemd/system/gdm3.service /etc/systemd/system/display-manager.service" ]
  # systemd-networkd-wait-online blocks boot for ~120s (it waits for every link
  # to be "online"); mask it so the graphical session comes up promptly.
  - [ systemctl, mask, systemd-networkd-wait-online.service ]
  - [ systemctl, disable, NetworkManager-wait-online.service ]
  # Sanity probe for the Vulkan stack (works without a display); GL probes need
  # an X server, so run those later inside the desktop session.
  - [ sh, -c, "vulkaninfo --summary >/var/log/gfx-vulkaninfo.txt 2>&1 || true" ]

# Grow the root fs to fill the resized disk.
growpart:
  mode: auto
  devices: ["/"]
resize_rootfs: true

package_update: true
package_upgrade: false

# Graphics userspace + a full GNOME desktop. The guest renders and DISPLAYS
# onscreen (the real use case: render-and-present, not off-screen), so benchmarks
# run inside a real desktop session shown through the QEMU GTK window. Session is
# GNOME on Xorg (X11) for best benchmark/DXVK/MangoHud compatibility.
packages:
  # Mesa: RADV (Vulkan), radeonsi (GL), virgl/venus client drivers
  - mesa-vulkan-drivers
  - mesa-utils
  - libgl1-mesa-dri
  - libglx-mesa0
  - libegl-mesa0
  - libgles2
  # Vulkan loader + tools
  - libvulkan1
  - vulkan-tools
  # GL/EGL inspection + onscreen demos (glxgears, glxinfo, eglinfo all in mesa-utils)
  - mesa-utils-bin
  # full GNOME desktop (brings GDM3, Xorg, GNOME Shell)
  - ubuntu-desktop-minimal
  # frame capture (Linux capture layer per design §4)
  - mangohud
  # misc
  - pciutils
  - jq
  - curl
  # frame capture (Linux capture layer per design §4)
  - mangohud
  # misc
  - pciutils
  - jq
  - curl

final_message: "graphics-benchmark guest ready after $UPTIME seconds"
