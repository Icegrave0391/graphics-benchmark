# Guest VM configuration for graphics-benchmark.
# Sourced by create-vmdisk.sh / start-vm.sh / ssh-vm.sh.
#
# The guest is a headless Ubuntu 24.04 cloud image (no desktop). Graphics is
# provided by the Mesa/Vulkan userspace installed via cloud-init, NOT by a
# desktop session — all benchmarks run CLI/headless (see docs/benchmark-design.md
# §4). The local desktop ISO is not used (its GUI installer can't run unattended).

# --- paths -------------------------------------------------------------------
GUESTDIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
VMDISKFOLDER="$GUESTDIR/vmdisk"
VMDISK="$VMDISKFOLDER/ubuntu-vm.qcow2"
SEEDISO="$VMDISKFOLDER/seed.iso"                    # cloud-init NoCloud seed
VMNAME="graphics-benchmark-ubuntu"

# Base cloud image (downloaded by create-vmdisk.sh if absent, then resized).
CLOUDIMG_RELEASE="${CLOUDIMG_RELEASE:-noble}"       # 24.04 = noble
CLOUDIMG_NAME="${CLOUDIMG_NAME:-${CLOUDIMG_RELEASE}-server-cloudimg-amd64.img}"
CLOUDIMG_URL="${CLOUDIMG_URL:-https://cloud-images.ubuntu.com/${CLOUDIMG_RELEASE}/current/${CLOUDIMG_NAME}}"
CLOUDIMG_CACHE="$VMDISKFOLDER/$CLOUDIMG_NAME"

# UEFI firmware (OVMF, installed by 00-base-kvm.sh). VARS is copied per-VM.
OVMF_CODE="/usr/share/OVMF/OVMF_CODE_4M.fd"
OVMF_VARS_SRC="/usr/share/OVMF/OVMF_VARS_4M.fd"
OVMF_VARS="$VMDISKFOLDER/OVMF_VARS.fd"

# --- guest credentials -------------------------------------------------------
# Default user is "user" with NO password (passwordless sudo, passwordless
# console login). SSH is key-based (empty-password SSH is refused by sshd).
USERNAME="user"
HOSTNAME="graphics-bench"
SSH_KEY="$GUESTDIR/.ssh/guest-key"                 # private key used by ssh-vm.sh
SSH_PUBKEY="$GUESTDIR/.ssh/guest-key.pub"          # injected into the guest

# --- VM runtime --------------------------------------------------------------
# Runtime QEMU is the source-built 10.2 in /usr/local (see 05-qemu-10.2.sh).
QEMU="${QEMU:-/usr/local/bin/qemu-system-x86_64}"
QEMU_IMG="${QEMU_IMG:-/usr/local/bin/qemu-img}"
MEMORY="${MEMORY:-8192}"        # MiB
VCPUS="${VCPUS:-8}"
DISK_SIZE="${DISK_SIZE:-60G}"   # cloud image is ~3.5G; resized up to this
SSH_HOSTFWD_PORT="${SSH_HOSTFWD_PORT:-2222}"   # host port -> guest 22

# --- pretty logging ----------------------------------------------------------
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m'
log_info() { echo -e "${GREEN}$1${NC}"; }
log_warn() { echo -e "${YELLOW}$1${NC}"; }
log_err()  { echo -e "${RED}$1${NC}" >&2; }
