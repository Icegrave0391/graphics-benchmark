# Windows guest VM configuration for graphics-benchmark.
# Sourced by create-vmdisk.sh / start-vm.sh / ssh-vm.sh.
#
# Unlike Linux there is no official Windows cloud image, so the guest is built
# from a Windows ISO via an unattended install (autounattend.xml on a seed ISO),
# with virtio drivers (virtio-win) for disk/net/balloon and the QEMU guest agent.
# Targets Windows 10 with UEFI but Secure Boot OFF and no TPM (simplest path).
# The primary virtualized graphics path for Windows is VFIO PASSTHROUGH
# (pt-windows: native AMD Windows driver, native DirectX); virtio-gpu 3D for
# Windows guests is immature (venus-windows is experimental — design §6).

# --- paths -------------------------------------------------------------------
GUESTDIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
VMDISKFOLDER="$GUESTDIR/vmdisk"
VMDISK="$VMDISKFOLDER/windows-vm.qcow2"
SEEDISO="$VMDISKFOLDER/autounattend.iso"            # autounattend.xml seed CD
VMNAME="graphics-benchmark-windows"

# Windows installer ISO — YOU provide this (see README "Getting a Windows ISO").
# Point WINDOWS_ISO at your Win10/Win11 x64 ISO.
WINDOWS_ISO="${WINDOWS_ISO:-$GUESTDIR/windows.iso}"

# virtio-win driver ISO (Red Hat) — downloaded by create-vmdisk.sh if absent.
VIRTIO_WIN_NAME="${VIRTIO_WIN_NAME:-virtio-win.iso}"
VIRTIO_WIN_URL="${VIRTIO_WIN_URL:-https://fedorapeople.org/groups/virt/virtio-win/direct-downloads/stable-virtio/virtio-win.iso}"
VIRTIO_WIN_ISO="$VMDISKFOLDER/$VIRTIO_WIN_NAME"

# UEFI firmware (plain OVMF — Secure Boot OFF). We use UEFI but not Secure Boot,
# and no TPM: simpler, and avoids Secure-Boot conflicts on the passthrough path.
# This targets Windows 10 (no TPM 2.0 requirement). For Windows 11 you would
# need TPM 2.0 (swtpm) and possibly a setup bypass — out of scope here.
OVMF_CODE="${OVMF_CODE:-/usr/share/OVMF/OVMF_CODE_4M.fd}"
OVMF_VARS_SRC="${OVMF_VARS_SRC:-/usr/share/OVMF/OVMF_VARS_4M.fd}"
OVMF_VARS="$VMDISKFOLDER/OVMF_VARS.fd"

# --- guest credentials -------------------------------------------------------
# Windows can't be truly passwordless for RDP/SSH, so we set a known password.
# Username and password are both "user" for simplicity. SSH (OpenSSH Server,
# built into Win10/11) also gets the public key.
USERNAME="${USERNAME:-user}"
PASSWORD="${PASSWORD:-user}"
HOSTNAME="${HOSTNAME:-graphics-bench}"
SSH_KEY="$GUESTDIR/.ssh/guest-key"
SSH_PUBKEY="$GUESTDIR/.ssh/guest-key.pub"

# --- VM runtime --------------------------------------------------------------
QEMU="${QEMU:-/usr/local/bin/qemu-system-x86_64}"
QEMU_IMG="${QEMU_IMG:-/usr/local/bin/qemu-img}"
MEMORY="${MEMORY:-8192}"        # MiB
VCPUS="${VCPUS:-8}"
DISK_SIZE="${DISK_SIZE:-80G}"   # Windows needs more space than Linux
SSH_HOSTFWD_PORT="${SSH_HOSTFWD_PORT:-2322}"   # host -> guest 22 (Win OpenSSH)
RDP_HOSTFWD_PORT="${RDP_HOSTFWD_PORT:-3389}"   # host -> guest 3389 (RDP)

# Used by the shared virtualization launchers (common.sh) to pick OS behaviour.
GUEST_OS="windows"

# --- pretty logging ----------------------------------------------------------
GREEN='\033[0;32m'; YELLOW='\033[0;33m'; RED='\033[0;31m'; NC='\033[0m'
log_info() { echo -e "${GREEN}$1${NC}"; }
log_warn() { echo -e "${YELLOW}$1${NC}"; }
log_err()  { echo -e "${RED}$1${NC}" >&2; }
