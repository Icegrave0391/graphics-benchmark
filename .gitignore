# macOS
.DS_Store

# Benchmark outputs
/results/*
!/results/.gitkeep
captures/

# Workload tool downloads + extracted/installed payloads (large, non-redistributable)
workloads/.cache/
workloads/gravitymark/GravityMark/
workloads/gravitymark/dx/GravityMark-win/
workloads/basemark-gpu/BasemarkGPU/
workloads/basemark-gpu/captures/
# DirectX-via-Proton runtime: wine prefix, captures, recorded versions
workloads/proton/prefix/
workloads/proton/captures/
workloads/proton/versions.txt

# Editor / OS
*.swp
.idea/
.vscode/

# Guest VM artifacts (large / generated)
*.iso
*.img
*.qcow2
environments/guest/*/vmdisk/
# NOTE: the guest SSH keypair (.ssh/guest-key{,.pub}) is intentionally committed.
# It only authenticates to throwaway benchmark VMs — no privacy concern — so a
# fresh clone can SSH in without regenerating keys.
