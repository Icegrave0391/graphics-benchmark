# macOS
.DS_Store

# Benchmark outputs
/results/*
!/results/.gitkeep
captures/

# Workload tool downloads + extracted/installed payloads (large, non-redistributable)
workloads/.cache/
workloads/l1-gpu-bound/GravityMark/
workloads/l2-real-world/BasemarkGPU/
# DX path: Proton wine prefix, extracted Windows builds, captures, recorded versions
workloads/dx/prefix/
workloads/dx/GravityMark-win/
workloads/dx/captures/
workloads/dx/versions.txt

# Editor / OS
*.swp
.idea/
.vscode/

# Guest VM artifacts (large / generated)
*.iso
*.img
*.qcow2
environments/guest/*/vmdisk/
# NOTE: the guest SSH keypair (.ssh/guest-key{,.pub}) is intentionally committed.
# It only authenticates to throwaway benchmark VMs — no privacy concern — so a
# fresh clone can SSH in without regenerating keys.
